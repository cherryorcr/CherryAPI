{
  "name": "cherryapi",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.1.3",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "test": "pnpm --filter @cherryapi/server test",
    "typecheck": "pnpm --filter @cherryapi/shared build && pnpm --filter @cherryapi/server typecheck && pnpm --filter @cherryapi/web typecheck"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
