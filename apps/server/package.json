{
  "name": "@cherryapi/server",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "inspect:openai-compatible": "tsx src/scripts/inspect-openai-compatible-request.ts",
    "inspect:openai-api": "tsx src/scripts/inspect-openai-api-request.ts",
    "inspect:codex": "tsx src/scripts/inspect-codex-request.ts",
    "inspect:claude": "tsx src/scripts/inspect-claude-request.ts",
    "start": "node dist/main.js"
  },
  "dependencies": {
    "@cherryapi/shared": "workspace:*",
    "@fastify/cors": "^10.0.2",
    "@fastify/static": "^9.1.3",
    "@libsql/client": "^0.15.4",
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.43.1",
    "fastify": "^5.3.3",
    "undici": "^7.25.0",
    "zod": "^3.25.28"
  }
}
