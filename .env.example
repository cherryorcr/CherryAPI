# Runtime mode. Use development locally and production for a built server.
NODE_ENV=development

# Fastify server listen port.
PORT=3000

# SQLite database URL. v1 supports local file-backed SQLite only.
# Relative paths are resolved from the server process working directory.
DATABASE_URL=file:./data/cherryapi.sqlite

# Admin bearer token for every /admin request.
# Change this before exposing the server beyond your local machine.
ADMIN_TOKEN=change-me

# Web console token. Keep this equal to ADMIN_TOKEN for local admin usage.
# Vite reads this from the repository root .env.
VITE_ADMIN_TOKEN=change-me

# Server URL used by the web console. Local development can use the Vite proxy
# or talk directly to the server. Direct mode is friendlier for built web assets.
VITE_API_TARGET=http://localhost:3000

# Optional built web asset directory for production/server-side static hosting.
# Docker sets this to /app/apps/web/dist.
# WEB_DIST_DIR=apps/web/dist

# Secret used to encrypt upstream account credentials at rest.
# Use a long random value and do not change it after accounts are created,
# otherwise existing encrypted credentials can no longer be decrypted.
ENCRYPTION_KEY=change-me-32-bytes-minimum

# Fastify/Pino log level: silent, fatal, error, warn, info, debug, trace.
LOG_LEVEL=info

# Optional outbound proxy variables. The proxy page can detect common local
# proxy ports, and the server also respects these process-level values.
# HTTPS_PROXY=http://127.0.0.1:7890
# HTTP_PROXY=http://127.0.0.1:7890
# ALL_PROXY=socks5://127.0.0.1:7890
# Docker containers should use the host gateway name for host-machine proxies:
# HTTPS_PROXY=http://host.docker.internal:7890

# Optional GitHub API version for GitHub Copilot related calls.
# GITHUB_API_VERSION=2022-11-28

# Codex OAuth callback listener host. Local source runs can keep 127.0.0.1.
# Docker sets this to 0.0.0.0 so the published 1455 port can receive callbacks.
# CODEX_CALLBACK_HOST=127.0.0.1
